<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>School Portal</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Segoe UI, Arial, sans-serif;
}

body{
    background:#eef3f8;
}

/* Header */

.header{
    background:#0d47a1;
    color:white;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 40px;
}

.header h1{
    font-size:32px;
}

.logo img{
    width:65px;
    height:65px;
    border-radius:50%;
    border:3px solid white;
}

/* Navigation */

.navbar{
    background:#1565c0;
    padding:15px;
    text-align:center;
}

.navbar a{
    color:white;
    text-decoration:none;
    margin:0 20px;
    font-size:18px;
    font-weight:bold;
}

.navbar a:hover{
    color:#ffeb3b;
}

/* Main Layout */

.main{
    display:flex;
    padding:20px;
    gap:20px;
}

/* Left Menu */

.menu{
    width:20%;
    background:white;
    border-radius:12px;
    box-shadow:0 2px 10px gray;
    padding:20px;
}

.menu h2{
    text-align:center;
    color:#0d47a1;
    margin-bottom:20px;
}

.menu a{
    display:block;
    background:#1976d2;
    color:white;
    text-decoration:none;
    padding:12px;
    margin:12px 0;
    text-align:center;
    border-radius:8px;
    transition:0.3s;
}

.menu a:hover{
    background:#0d47a1;
}

/* Content */

.content{
    width:60%;
    background:white;
    border-radius:12px;
    box-shadow:0 2px 10px gray;
    padding:30px;
    min-height:420px;
}

.content h2{
    color:#0d47a1;
    margin-bottom:20px;
}

.content p{
    font-size:18px;
    margin-top:15px;
}

/* Right Panel */

.side{
    width:20%;
    background:white;
    border-radius:12px;
    box-shadow:0 2px 10px gray;
    padding:20px;
    text-align:center;
}

.side img{
    width:150px;
    margin-top:20px;
}

/* Footer */

.footer{
    background:#0d47a1;
    color:white;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 30px;
    margin-top:20px;
}

.footer a{
    color:white;
    text-decoration:none;
    margin-right:15px;
}

.footer a:hover{
    color:yellow;
}

</style>

</head>

<body>

<!-- Header -->

<div class="header">

    <h1>School Portal</h1>

    <div class="logo">

        <!-- Replace logo.png with your own logo later -->
        <img th:src="@{/images/logo.png}" alt="Logo">

    </div>

</div>

<!-- Navigation -->

<div class="navbar">

    <a href="/">Home</a>

    <a href="/about">About</a>

    <a href="/contact">Contact</a>

    <a href="/student">Student</a>

</div>

<!-- Main -->

<div class="main">

    <!-- Left Menu -->

    <div class="menu">

        <h2>Menu</h2>

        <a href="/a">A</a>

        <a href="/b">B</a>

        <a href="/c">C</a>

    </div>

    <!-- Center -->

    <div class="content">

        <h2 th:text="${title}"></h2>

        <p th:text="${message}"></p>

        <p th:if="${name}">
            <b>Name :</b>
            <span th:text="${name}"></span>
        </p>

        <p th:if="${course}">
            <b>Course :</b>
            <span th:text="${course}"></span>
        </p>

        <p th:if="${semester}">
            <b>Semester :</b>
            <span th:text="${semester}"></span>
        </p>

        <p th:if="${college}">
            <b>College :</b>
            <span th:text="${college}"></span>
        </p>

    </div>

    <!-- Right -->

    <div class="side">

        <h2>School</h2>

        <img th:src="@{/images/logo.png}" alt="School Logo">

        <br><br>

        <h3>Excellence in Education</h3>

    </div>

</div>

<!-- Footer -->

<div class="footer">

    <div>

        <a href="https://www.facebook.com" target="_blank">Facebook</a>

        <a href="https://www.instagram.com" target="_blank">Instagram</a>

        <a href="https://www.linkedin.com" target="_blank">LinkedIn</a>

    </div>

    <div>

        © 2026 School Portal

    </div>

    <div>

        Contact Us : +91 9999999999

    </div>

</div>

</body>

</html>